.timeline { padding: 20rpx 0; }

.tl-item {
  display: flex;
  padding-bottom: 40rpx;
  position: relative;
}

.tl-item::after {
  content: '';
  position: absolute;
  left: 13rpx;
  top: 32rpx;
  width: 2rpx;
  height: calc(100% - 8rpx);
  background: #e5e5e5;
}

.tl-item-last::after { display: none; }

.tl-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.dot-done { background: #07C160; }
.dot-current { background: #1A6FB5; }
.dot-pending { background: #ccc; }

.tl-dot-inner {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fff;
}

.tl-content { flex: 1; }
.tl-title { font-size: 30rpx; color: #333; display: block; }
.tl-time { font-size: 24rpx; color: #999; display: block; margin-top: 6rpx; }
.tl-desc { font-size: 26rpx; color: #666; display: block; margin-top: 8rpx; background: #f5f5f5; padding: 12rpx; border-radius: 8rpx; }

.tl-empty { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }
