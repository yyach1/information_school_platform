<view class="timeline">
  <block wx:for="{{events}}" wx:key="index">
    <view class="tl-item {{index === events.length - 1 ? 'tl-item-last' : ''}}">
      <view class="tl-dot {{item.status === 'DONE' ? 'dot-done' : item.status === 'CURRENT' ? 'dot-current' : 'dot-pending'}}">
        <view class="tl-dot-inner"></view>
      </view>
      <view class="tl-content">
        <text class="tl-title">{{item.nodeName || item.message}}</text>
        <text class="tl-time" wx:if="{{item.time}}">{{item.time}}</text>
        <text class="tl-desc" wx:if="{{item.comment}}">{{item.comment}}</text>
      </view>
    </view>
  </block>

  <view class="tl-empty" wx:if="{{!events || events.length === 0}}">
    <text>暂无进度记录</text>
  </view>
</view>
