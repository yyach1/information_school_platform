@import "../../../styles/common.wxss";

.detail-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.detail-title { font-size: 34rpx; font-weight: 600; color: #333; }

.current-node {
  background: #E8F2FA; border-radius: 12rpx; padding: 24rpx;
  border-left: 6rpx solid #1A6FB5;
}
.node-label { font-size: 24rpx; color: #1A6FB5; display: block; }
.node-name { font-size: 32rpx; font-weight: 600; color: #333; display: block; margin: 8rpx 0; }
.node-role { font-size: 26rpx; color: #666; }

.material-card {
  background: #f9f9f9; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx;
}
.material-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10rpx; }
.material-type { font-size: 28rpx; color: #333; font-weight: 500; }
.material-file { font-size: 24rpx; color: #1A6FB5; word-break: break-all; }

.actions { padding: 20rpx; }
