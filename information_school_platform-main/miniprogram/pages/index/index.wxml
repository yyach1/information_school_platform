<view class="page">
  <!-- 用户信息栏 -->
  <view class="header">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-text">
        <text class="user-name">{{userInfo.realName || '同学你好'}}</text>
        <text class="user-class">{{userInfo.className}} {{userInfo.studentNo}}</text>
      </view>
    </view>
  </view>

  <!-- 通知待办 -->
  <view class="card notice-card" wx:if="{{notices.length}}">
    <view class="card-title">
      <text>待办提醒</text>
      <text class="notice-badge">{{notices.length}}</text>
    </view>
    <view class="notice-item" wx:for="{{notices}}" wx:key="id" bindtap="goNotice" data-id="{{item.id}}">
      <view class="notice-dot {{item.readStatus === 'UNREAD' ? 'dot-red' : ''}}"></view>
      <view class="notice-body">
        <text class="notice-title">{{item.title}}</text>
        <text class="notice-time">{{item.createTime}}</text>
      </view>
      <text class="notice-arrow">></text>
    </view>
  </view>

  <!-- 当前流程 -->
  <view class="card">
    <view class="card-title">我的流程</view>
    <view class="process-list" wx:if="{{processes.length}}">
      <view class="process-item" wx:for="{{processes}}" wx:key="id" bindtap="goProgress" data-id="{{item.id}}">
        <view class="process-left">
          <text class="process-name">{{item.process.name}}</text>
          <text class="process-status tag {{item.status === 'IN_PROGRESS' ? 'tag-in-progress' : 'tag-completed'}}">{{item.status === 'IN_PROGRESS' ? '进行中' : '已完成'}}</text>
        </view>
        <view class="process-right">
          <text class="process-node">{{item.currentNode ? item.currentNode.nodeName : ''}}</text>
          <text class="process-arrow">></text>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text>暂无进行中的流程</text>
      <view class="btn-outline" style="margin-top:20rpx" bindtap="goApplyProcess">办理党团流程</view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="card">
    <view class="card-title">快速入口</view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goApplyProcess">
        <view class="quick-icon icon-process"></view>
        <text class="quick-label">党团流程</text>
      </view>
      <view class="quick-item" bindtap="goUploadMaterial">
        <view class="quick-icon icon-upload"></view>
        <text class="quick-label">材料上传</text>
      </view>
      <view class="quick-item" bindtap="goApplyCertificate">
        <view class="quick-icon icon-cert"></view>
        <text class="quick-label">证明办理</text>
      </view>
      <view class="quick-item" bindtap="goQA">
        <view class="quick-icon icon-qa"></view>
        <text class="quick-label">智能问答</text>
      </view>
    </view>
  </view>
</view>
