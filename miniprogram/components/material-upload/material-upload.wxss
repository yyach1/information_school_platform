.upload-group { padding: 0; }

.upload-header { margin-bottom: 20rpx; }
.upload-title { font-size: 30rpx; font-weight: 600; color: #333; }

.material-item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.material-info { margin-bottom: 16rpx; }
.material-name { font-size: 28rpx; color: #333; }
.material-name .required { color: #FA5151; }
.material-hint { display: block; font-size: 24rpx; color: #999; margin-top: 6rpx; }

.material-file { display: flex; align-items: center; flex-wrap: wrap; }
.file-name { font-size: 26rpx; color: #1A6FB5; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.progress-bar { width: 100%; height: 8rpx; background: #e5e5e5; border-radius: 4rpx; margin-top: 10rpx; }
.progress-fill { height: 100%; background: #1A6FB5; border-radius: 4rpx; transition: width 0.3s; }

.file-uploaded { font-size: 24rpx; color: #07C160; margin-right: 16rpx; }
.file-remove { font-size: 24rpx; color: #FA5151; }

.material-upload-btn {
  border: 1px dashed #ccc;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}
.material-upload-btn:active { background: #f0f0f0; }
