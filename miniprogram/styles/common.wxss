/* 颜色变量 */
page {
  --primary: #1A6FB5;
  --primary-light: #E8F2FA;
  --success: #07C160;
  --warning: #FF9500;
  --danger: #FA5151;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg-default: #f5f5f5;
  --bg-white: #ffffff;
  --border: #e5e5e5;
  --radius: 12rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: var(--radius);
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 通用按钮 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius);
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
  margin: 20rpx;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-outline {
  border: 1px solid var(--primary);
  color: var(--primary);
  background: #fff;
  border-radius: var(--radius);
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  text-align: center;
}

.btn-disabled {
  background: #ccc;
  color: #fff;
  border-radius: var(--radius);
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
  margin: 20rpx;
}

/* 状态标签 */
.tag-pending { color: #FF9500; background: #FFF3E0; }
.tag-approved { color: #1A6FB5; background: #E8F2FA; }
.tag-returned { color: #FA5151; background: #FFEBEE; }
.tag-issued { color: #07C160; background: #E8F5E9; }
.tag-in-progress { color: #1A6FB5; background: #E8F2FA; }
.tag-completed { color: #07C160; background: #E8F5E9; }

.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

/* 表单 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.form-label .required {
  color: var(--danger);
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg-default);
  border-radius: var(--radius);
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--bg-default);
  border-radius: var(--radius);
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-hint);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  font-size: 28rpx;
}

/* 加载更多 */
.loading-tip {
  text-align: center;
  padding: 20rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}

/* 进度节点颜色 */
.node-done { color: var(--success); }
.node-current { color: var(--primary); }
.node-pending { color: var(--text-hint); }
