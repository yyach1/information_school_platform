<view class="page">
  <!-- 流程列表 -->
  <view class="card" wx:for="{{processes}}" wx:key="id">
    <view class="process-header" bindtap="goDetail" data-id="{{item.id}}">
      <view class="process-info">
        <text class="process-name">{{item.process.name}}</text>
        <text class="tag {{item.status === 'IN_PROGRESS' ? 'tag-in-progress' : 'tag-completed'}}">
          {{item.status === 'IN_PROGRESS' ? '进行中' : '已完成'}}
        </text>
      </view>
      <text class="process-arrow">></text>
    </view>

    <!-- 简略时间轴 -->
    <view class="mini-timeline" wx:if="{{item.nodes && item.nodes.length}}">
      <view class="mini-node" wx:for="{{item.nodes}}" wx:key="id" wx:for-item="node">
        <view class="mini-dot {{node.status === 'DONE' ? 'dot-done' : node.status === 'CURRENT' ? 'dot-current' : 'dot-pending'}}"></view>
        <text class="mini-label {{node.status === 'CURRENT' ? 'label-active' : ''}}">{{node.nodeName}}</text>
      </view>
    </view>

    <view class="process-footer">
      <text class="process-time">开始时间：{{item.startTime}}</text>
      <text class="process-time">更新时间：{{item.updateTime}}</text>
      <view class="btn-outline" bindtap="goDetail" data-id="{{item.id}}">查看详情</view>
    </view>
  </view>

  <!-- 空白 -->
  <view class="empty-state" wx:if="{{!processes.length && !loading}}">
    <text>暂无流程记录</text>
    <text style="color:#999;font-size:24rpx;margin-top:10rpx">去首页发起新的党团流程</text>
  </view>

  <!-- 可发起的新流程 -->
  <view class="card" style="margin-top: 30rpx">
    <view class="card-title">可办理的流程</view>
    <view class="process-item" wx:for="{{availableProcesses}}" wx:key="id">
      <view class="process-left">
        <text class="process-name">{{item.name}}</text>
        <text class="process-desc">{{item.type}}</text>
      </view>
      <view class="btn-outline" bindtap="startProcess" data-id="{{item.id}}">立即办理</view>
    </view>
    <view class="empty-state" wx:if="{{!availableProcesses.length}}" style="padding:40rpx 0">
      <text style="font-size:24rpx">没有可发起的流程</text>
    </view>
  </view>
</view>
