@import "../../styles/common.wxss";

page { background: #fff; display: flex; flex-direction: column; height: 100vh; }

.quick-questions { flex: 1; overflow-y: auto; }

.quick-item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.quick-item:last-child { border-bottom: none; }
.quick-text { font-size: 28rpx; color: #333; }
.quick-arrow { color: #ccc; font-size: 28rpx; }

.chat-area { flex: 1; padding: 20rpx; overflow-y: auto; }

.msg-item { margin-bottom: 30rpx; }

.msg-bubble {
  max-width: 80%; padding: 20rpx 24rpx; border-radius: 16rpx;
  font-size: 28rpx; line-height: 1.6; display: inline-block;
}

.msg-user {
  background: #1A6FB5; color: #fff; float: right; border-bottom-right-radius: 4rpx;
}

.msg-bot {
  background: #f0f0f0; color: #333; float: left; border-bottom-left-radius: 4rpx;
}

.msg-item::after { content: ''; display: block; clear: both; }

.msg-extra { padding: 16rpx 0 0 10rpx; }
.link-item {
  display: block; font-size: 26rpx; color: #1A6FB5; padding: 8rpx 0; text-decoration: underline;
}

.input-bar {
  display: flex; align-items: center; padding: 16rpx 20rpx; background: #f5f5f5;
  border-top: 1rpx solid #e5e5e5;
}

.chat-input {
  flex: 1; height: 74rpx; background: #fff; border-radius: 37rpx;
  padding: 0 30rpx; font-size: 28rpx;
}

.send-btn {
  width: 120rpx; height: 74rpx; line-height: 74rpx; text-align: center;
  font-size: 28rpx; color: #999; margin-left: 16rpx;
}
.send-btn.send-active { color: #1A6FB5; font-weight: 600; }
