.qa-page { display: flex; flex-direction: column; height: 100vh; background: #f7f8fa; }

/* 欢迎区 */
.welcome-area { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 60rpx 40rpx 30rpx; overflow-y: auto; }
.welcome-icon { font-size: 96rpx; margin-bottom: 20rpx; }
.welcome-title { font-size: 40rpx; font-weight: 700; color: #1a1a2e; margin-bottom: 12rpx; }
.welcome-desc { font-size: 26rpx; color: #999; text-align: center; margin-bottom: 50rpx; line-height: 1.6; }

.quick-section { width: 100%; }
.section-title { font-size: 28rpx; color: #666; margin-bottom: 20rpx; font-weight: 500; }
.quick-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.quick-tag {
  background: #fff; border-radius: 40rpx; padding: 18rpx 30rpx;
  font-size: 26rpx; color: #333; border: 1rpx solid #e8e8e8;
  transition: all .2s;
}
.quick-tag:active { background: #e8f0fe; border-color: #1A6FB5; color: #1A6FB5; }

/* 对话顶栏 */
.chat-header { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 30rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.chat-title { font-size: 30rpx; font-weight: 600; color: #333; }
.new-chat-btn { font-size: 26rpx; color: #1A6FB5; padding: 8rpx 20rpx; border: 1rpx solid #1A6FB5; border-radius: 30rpx; }
.new-chat-btn:active { background: #e8f0fe; }

/* 对话区 */
.chat-area { flex: 1; padding: 20rpx 24rpx; overflow-y: auto; }

.msg-wrapper { margin-bottom: 28rpx; }
.msg-row { display: flex; align-items: flex-start; gap: 12rpx; }
.msg-left { justify-content: flex-start; }
.msg-right { justify-content: flex-end; }

.msg-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; flex-shrink: 0; background: #fff; }

.msg-body { max-width: 75%; }

.msg-bubble {
  padding: 18rpx 24rpx; border-radius: 18rpx; font-size: 28rpx;
  line-height: 1.7; word-break: break-all;
}
.bubble-user { background: linear-gradient(135deg, #1A6FB5, #2b8fd4); color: #fff; border-bottom-right-radius: 4rpx; }
.bubble-bot { background: #fff; color: #333; border-bottom-left-radius: 4rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,.04); }

.msg-links { margin-top: 10rpx; display: flex; flex-wrap: wrap; gap: 12rpx; }
.link-btn {
  background: #e8f0fe; color: #1A6FB5; font-size: 24rpx;
  padding: 10rpx 20rpx; border-radius: 30rpx; border: 1rpx solid #bdd6f5;
}
.link-btn:active { background: #d0e2f9; }

/* 输入栏 */
.input-bar {
  display: flex; align-items: center; padding: 16rpx 20rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff; border-top: 1rpx solid #eee; gap: 16rpx;
}
.chat-input {
  flex: 1; height: 72rpx; background: #f5f5f5; border-radius: 36rpx;
  padding: 0 28rpx; font-size: 28rpx; color: #333;
}
.send-btn {
  flex-shrink: 0; height: 72rpx; line-height: 72rpx; padding: 0 20rpx;
  font-size: 28rpx; color: #bbb; border-radius: 36rpx; transition: .2s;
}
.send-btn.send-active { color: #fff; background: #1A6FB5; font-weight: 500; }
