<view class="qa-page">
  <!-- 欢迎页 -->
  <view class="welcome-area" wx:if="{{messages.length === 0}}">
    <view class="welcome-icon">💬</view>
    <view class="welcome-title">智能问答助手</view>
    <view class="welcome-desc">关于党团流程、证明办理、材料提交等问题，都可以问我</view>

    <view class="quick-section">
      <view class="section-title">你可能想问</view>
      <view class="quick-tags">
        <view class="quick-tag" wx:for="{{quickList}}" wx:key="index" bindtap="quickAsk" data-question="{{item}}">
          {{item}}
        </view>
      </view>
    </view>
  </view>

  <!-- 对话区 -->
  <view class="chat-header" wx:if="{{messages.length > 0}}">
    <text class="chat-title">智能问答</text>
    <view class="new-chat-btn" bindtap="clearChat">新问题</view>
  </view>
  <scroll-view class="chat-area" scroll-y scroll-into-view="msg-{{messages.length - 1}}" wx:if="{{messages.length > 0}}">
    <view class="msg-wrapper" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <view class="msg-row {{item.role === 'user' ? 'msg-right' : 'msg-left'}}">
        <view class="msg-avatar" wx:if="{{item.role === 'bot'}}">🤖</view>
        <view class="msg-body">
          <view class="msg-bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-bot'}}">
            <text wx:if="{{item.role === 'bot' && item.thinking}}">正在思考...</text>
            <text wx:else>{{item.content}}</text>
          </view>
          <view class="msg-links" wx:if="{{item.links && item.links.length}}">
            <view class="link-btn" wx:for="{{item.links}}" wx:key="index" wx:for-item="link" bindtap="openLink" data-url="{{link.url}}">
              {{link.title}} →
            </view>
          </view>
        </view>
        <view class="msg-avatar" wx:if="{{item.role === 'user'}}">👤</view>
      </view>
    </view>
  </scroll-view>

  <!-- 输入栏 -->
  <view class="input-bar">
    <input class="chat-input" placeholder="输入问题..." value="{{input}}" bindinput="onInput" bindconfirm="send" confirm-type="send" adjust-position="{{false}}" cursor-spacing="12" />
    <view class="send-btn {{input ? 'send-active' : ''}}" bindtap="send">发送</view>
  </view>
</view>
