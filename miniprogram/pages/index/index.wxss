@import "../../styles/common.wxss";

.header {
  background: linear-gradient(135deg, #1A6FB5, #3B8ED4);
  padding: 40rpx 30rpx 50rpx;
}

.user-info { display: flex; align-items: center; }

.avatar {
  width: 90rpx; height: 90rpx; border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.4); margin-right: 20rpx;
  background: rgba(255,255,255,0.2);
}

.user-name { font-size: 36rpx; color: #fff; font-weight: 600; display: block; }
.user-class { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; }

.card-title {
  font-size: 32rpx; font-weight: 600; color: #333;
  margin-bottom: 24rpx; display: flex; align-items: center; justify-content: space-between;
}

.notice-card { padding-bottom: 10rpx; }

.notice-badge {
  background: #FA5151; color: #fff; font-size: 22rpx; border-radius: 50%;
  min-width: 36rpx; height: 36rpx; text-align: center; line-height: 36rpx; padding: 0 8rpx;
}

.notice-item { display: flex; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.notice-item:last-child { border-bottom: none; }

.notice-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #ccc; margin-right: 16rpx; flex-shrink: 0; }
.notice-dot.dot-red { background: #FA5151; }

.notice-body { flex: 1; }
.notice-title { font-size: 28rpx; color: #333; display: block; }
.notice-time { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.notice-arrow { color: #ccc; font-size: 28rpx; }

.process-item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.process-item:last-child { border-bottom: none; }

.process-left { display: flex; flex-direction: column; }
.process-name { font-size: 30rpx; color: #333; margin-bottom: 8rpx; }
.process-right { display: flex; align-items: center; }
.process-node { font-size: 26rpx; color: #1A6FB5; margin-right: 10rpx; }
.process-arrow { color: #ccc; }

.quick-grid { display: flex; justify-content: space-around; }
.quick-item { display: flex; flex-direction: column; align-items: center; padding: 10rpx; }

.quick-icon {
  width: 90rpx; height: 90rpx; border-radius: 50%; margin-bottom: 12rpx;
}

.icon-process { background: #E8F2FA; }
.icon-upload { background: #FFF3E0; }
.icon-cert { background: #E8F5E9; }
.icon-qa { background: #F3E5F5; }

.quick-label { font-size: 24rpx; color: #666; }
