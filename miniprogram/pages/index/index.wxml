<view class="page">
  <!-- 头部 -->
  <view class="header">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-text">
        <text class="user-name">{{greeting}}，{{userInfo.realName || '同学'}}</text>
        <text class="user-class" wx:if="{{userInfo.className}}">{{userInfo.className}} · {{userInfo.studentNo || userInfo.role}}</text>
      </view>
    </view>
  </view>

  <!-- 管理员提示 -->
  <view class="card tip-card" wx:if="{{hasRoleIssue}}">
    <text class="tip-text">管理员账号可查看党团流程和智能问答，但「我的证明」「材料审核」等功能需以学生身份登录。请用管理后台创建学生测试账号。</text>
  </view>

  <!-- 流程卡片 -->
  <view class="card">
    <view class="card-title">我的党团进度</view>
    <view wx:if="{{processes.length}}">
      <view class="process-item" wx:for="{{processes}}" wx:key="id" bindtap="startProcess" data-id="{{item.id}}">
        <view class="process-left">
          <text class="process-name">{{item.name}}</text>
        </view>
        <view class="process-right">
          <text class="process-node">进入办理</text>
          <text class="process-arrow">></text>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:else>
      <text>暂无可办理流程 · 请联系管理员配置</text>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="card">
    <view class="card-title">快捷服务</view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goApplyProcess">
        <view class="quick-icon icon-process">📋</view>
        <text class="quick-label">党团进度</text>
      </view>
      <view class="quick-item" bindtap="goUploadMaterial">
        <view class="quick-icon icon-upload">📎</view>
        <text class="quick-label">材料上传</text>
      </view>
      <view class="quick-item" bindtap="goApplyCertificate">
        <view class="quick-icon icon-cert">📜</view>
        <text class="quick-label">证明办理</text>
      </view>
      <view class="quick-item" bindtap="goQA">
        <view class="quick-icon icon-qa">💬</view>
        <text class="quick-label">智能问答</text>
      </view>
    </view>
  </view>
</view>
