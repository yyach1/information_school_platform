@import "../../../styles/common.wxss";

.type-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }

.type-item {
  width: calc(50% - 8rpx); background: #f9f9f9; border-radius: 12rpx;
  padding: 24rpx; border: 2rpx solid transparent; box-sizing: border-box;
}
.type-item.type-selected { border-color: #1A6FB5; background: #E8F2FA; }

.type-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 8rpx; }
.type-desc { font-size: 22rpx; color: #999; display: block; }

.attach-area { text-align: center; padding: 30rpx 0; }
.attach-btn {
  border: 1px dashed #ccc; border-radius: 12rpx; padding: 30rpx;
  color: #999; font-size: 28rpx; margin-bottom: 12rpx;
}

.attach-hint { font-size: 24rpx; color: #ccc; }

.attach-file { display: flex; flex-wrap: wrap; align-items: center; }
.file-name { font-size: 26rpx; color: #1A6FB5; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.progress-bar { width: 100%; height: 8rpx; background: #e5e5e5; border-radius: 4rpx; margin-top: 10rpx; }
.progress-fill { height: 100%; background: #1A6FB5; border-radius: 4rpx; transition: width 0.3s; }

.file-uploaded { font-size: 24rpx; color: #07C160; margin-right: 16rpx; }
.file-remove { font-size: 24rpx; color: #FA5151; }
