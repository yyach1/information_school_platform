@import "../../../styles/common.wxss";

.perm-tip {
  margin: 80rpx 32rpx;
  padding: 60rpx 40rpx;
  background: #FFF9E6;
  border-radius: 24rpx;
  border: 1rpx solid #FFE8A0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.perm-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
}

.perm-tip-text {
  font-size: 28rpx; color: #8B6914;
  line-height: 1.8; text-align: center;
}

.perm-actions {
  margin-top: 36rpx;
}

.perm-actions .btn-outline {
  border: 1px solid #1A6FB5;
  color: #1A6FB5;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 18rpx 48rpx;
}

.filter-bar {
  display: flex; background: #fff; padding: 20rpx 30rpx; margin-bottom: 10rpx;
  border-bottom: 1rpx solid #e5e5e5;
}
.filter-item { font-size: 28rpx; color: #1A6FB5; margin-right: 40rpx; }

.cert-item { margin-top: 10rpx; }
.cert-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.cert-title { font-size: 30rpx; color: #333; font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-right: 16rpx; }
.cert-meta { display: flex; align-items: center; gap: 20rpx; }
.cert-type { font-size: 24rpx; color: #1A6FB5; }
.cert-date { font-size: 24rpx; color: #999; }

.cert-action { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.download-link { font-size: 26rpx; color: #07C160; }

.fixed-bottom { position: fixed; bottom: 0; left: 0; right: 0; }
