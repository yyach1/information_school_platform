<view class="page">
  <!-- 权限提示 -->
  <view class="perm-tip" wx:if="{{permissionDenied}}">
    <text class="perm-tip-text">「我的证明」仅面向学生角色开放，当前管理员账号无法查看。\n\n请通过管理后台创建学生测试账号后重新登录。</text>
  </view>

  <block wx:if="{{!permissionDenied}}">
    <!-- 筛选栏 -->
  <view class="filter-bar">
    <picker mode="selector" range="{{statusOptions}}" range-key="label" bindchange="onStatusFilter">
      <text class="filter-item">{{activeStatusLabel || '全部状态'}}</text>
    </picker>
    <picker mode="selector" range="{{typeOptions}}" range-key="label" bindchange="onTypeFilter">
      <text class="filter-item">{{activeTypeLabel || '全部类型'}}</text>
    </picker>
  </view>

  <!-- 列表 -->
  <view class="card cert-item" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="cert-header">
      <text class="cert-title">{{item.title}}</text>
      <text class="tag {{item.status === 'PENDING' ? 'tag-pending' : item.status === 'APPROVED' ? 'tag-approved' : item.status === 'RETURNED' ? 'tag-returned' : 'tag-issued'}}">
        {{item.status === 'PENDING' ? '待审核' : item.status === 'APPROVED' ? '已通过' : item.status === 'RETURNED' ? '已退回' : '已发放'}}
      </text>
    </view>
    <view class="cert-meta">
      <text class="cert-type">{{item.certTypeLabel || item.certType}}</text>
      <text class="cert-date">{{item.applyTime}}</text>
    </view>
    <view class="cert-action" wx:if="{{item.status === 'ISSUED'}}">
      <text class="download-link">下载证明 ></text>
    </view>
  </view>

  <!-- 空 -->
  <view class="empty-state" wx:if="{{!list.length && !loading}}">
    <text>暂无证明申请记录</text>
  </view>

  <!-- 申请按钮 -->
  <view class="btn-primary fixed-bottom" bindtap="goApply">申请新证明</view>
  </block>
</view>
