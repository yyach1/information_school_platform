@import "../../../styles/common.wxss";

.detail-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.detail-title { font-size: 34rpx; font-weight: 600; color: #333; flex: 1; margin-right: 16rpx; }

.info-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: #999; } .info-value { font-size: 28rpx; color: #333; }

.info-group { margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid #f0f0f0; }
.info-text { font-size: 28rpx; color: #666; margin-top: 12rpx; display: block; line-height: 1.6; }
.info-link { font-size: 28rpx; color: #1A6FB5; margin-top: 8rpx; display: block; text-decoration: underline; }

.return-card { border-left: 6rpx solid #FA5151; }
