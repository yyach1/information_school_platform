<view class="page">
  <view class="card">
    <view class="detail-header">
      <text class="detail-title">{{detail.title || '加载中...'}}</text>
      <text class="tag {{detail.status === 'PENDING' ? 'tag-pending' : detail.status === 'APPROVED' ? 'tag-approved' : detail.status === 'RETURNED' ? 'tag-returned' : 'tag-issued'}}">
        {{detail.status === 'PENDING' ? '待审核' : detail.status === 'APPROVED' ? '已通过' : detail.status === 'RETURNED' ? '已退回' : '已发放'}}
      </text>
    </view>

    <view class="info-row"><text class="info-label">证明类型</text><text class="info-value">{{detail.certType}}</text></view>
    <view class="info-row"><text class="info-label">申请人</text><text class="info-value">{{detail.studentName}} {{detail.studentNo}}</text></view>
    <view class="info-row"><text class="info-label">班级</text><text class="info-value">{{detail.className}}</text></view>
    <view class="info-row"><text class="info-label">申请时间</text><text class="info-value">{{detail.applyTime}}</text></view>

    <view class="info-group" wx:if="{{detail.description}}">
      <text class="info-label">申请说明</text>
      <text class="info-text">{{detail.description}}</text>
    </view>

    <view class="info-group" wx:if="{{detail.attachmentUrl}}">
      <text class="info-label">附件</text>
      <text class="info-link" bindtap="previewFile">{{detail.attachmentName}}</text>
    </view>
  </view>

  <!-- 审核信息 -->
  <view class="card" wx:if="{{detail.status === 'APPROVED' || detail.status === 'ISSUED'}}">
    <view class="card-title">审核信息</view>
    <view class="info-row"><text class="info-label">审核人</text><text class="info-value">{{detail.approverName}}</text></view>
    <view class="info-row"><text class="info-label">审核时间</text><text class="info-value">{{detail.approveTime}}</text></view>
    <view class="info-group" wx:if="{{detail.approveComment}}">
      <text class="info-label">审核意见</text>
      <text class="info-text">{{detail.approveComment}}</text>
    </view>
  </view>

  <!-- 退回信息 -->
  <view class="card return-card" wx:if="{{detail.status === 'RETURNED'}}">
    <view class="card-title" style="color:#FA5151">退回原因</view>
    <text class="info-text">{{detail.approveComment}}</text>
    <view class="btn-primary" style="margin: 24rpx 0 0" bindtap="resubmit">修改并重新提交</view>
  </view>

  <!-- 进度 -->
  <view class="card" wx:if="{{detail.progressNodes && detail.progressNodes.length}}">
    <view class="card-title">办理进度</view>
    <timeline events="{{detail.progressNodes}}"></timeline>
  </view>

  <!-- 下载 -->
  <view class="btn-primary" wx:if="{{detail.status === 'ISSUED'}}" bindtap="downloadPdf">
    下载证明PDF
  </view>
</view>
