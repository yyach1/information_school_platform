<view class="page">
  <!-- 头部个人信息 -->
  <view class="header">
    <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-text">
      <text class="user-name">{{userInfo.realName || '未登录'}}</text>
      <text class="user-detail" wx:if="{{userInfo.className}}">{{userInfo.className}}</text>
      <text class="user-detail" wx:elif="{{userInfo.role}}">{{roleLabel}}</text>
    </view>
  </view>

  <!-- 信息卡片 -->
  <view class="card">
    <view class="info-row">
      <text class="info-label">学号/工号</text>
      <text class="info-value">{{userInfo.studentNo || userInfo.teacherNo || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">角色</text>
      <text class="info-value">{{roleLabel}}</text>
    </view>
    <view class="info-row" wx:if="{{userInfo.phone}}">
      <text class="info-label">手机号</text>
      <text class="info-value">{{userInfo.phone}}</text>
    </view>
    <view class="info-row" wx:if="{{userInfo.email}}">
      <text class="info-label">邮箱</text>
      <text class="info-value">{{userInfo.email}}</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="card">
    <view class="logout-btn" bindtap="handleLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>
</view>
