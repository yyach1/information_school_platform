@import "../../styles/common.wxss";

/* ---- 头部 ---- */
.header {
  background: linear-gradient(160deg, #1A6FB5 0%, #2B8FD4 50%, #48A9E6 100%);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
}

.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 28rpx;
  background: rgba(255,255,255,0.25);
}

.user-text { display: flex; flex-direction: column; }

.user-name { font-size: 38rpx; color: #fff; font-weight: 700; }

.user-detail { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; }

/* ---- 信息卡片 ---- */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 24rpx 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-child { border-bottom: none; }

.info-label { font-size: 28rpx; color: #999; }
.info-value { font-size: 28rpx; color: #333; }

/* ---- 退出登录 ---- */
.logout-btn {
  display: flex; align-items: center; justify-content: center;
  padding: 20rpx 0;
}

.logout-text { font-size: 30rpx; color: #FA5151; }
