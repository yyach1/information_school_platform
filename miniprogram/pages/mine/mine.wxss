@import "../../styles/common.wxss";

/* ---- 头部 ---- */
.header {
  background: linear-gradient(160deg, #1A6FB5 0%, #2B8FD4 50%, #48A9E6 100%);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
}

.avatar-wrap { position: relative; margin-right: 28rpx; }
.avatar-img {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.25);
}
.avatar-camera { position: absolute; right: -4rpx; bottom: -4rpx; width: 40rpx; height: 40rpx; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,.15); }

.user-text { display: flex; flex-direction: column; }
.user-name { font-size: 38rpx; color: #fff; font-weight: 700; }
.user-detail { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 6rpx; }

/* ---- 信息卡片 ---- */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 24rpx 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: #999; }
.info-value { font-size: 28rpx; color: #333; }

/* ---- 操作 ---- */
.action-row { display: flex; align-items: center; justify-content: space-between; font-size: 28rpx; color: #333; }
.action-arrow { font-size: 36rpx; color: #ccc; }

/* ---- 退出登录 ---- */
.logout-btn { display: flex; align-items: center; justify-content: center; }
.logout-text { font-size: 30rpx; color: #FA5151; }

/* ---- 弹窗 ---- */
.dialog-mask { position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.dialog-card { width: 600rpx; background: #fff; border-radius: 20rpx; padding: 40rpx 30rpx 30rpx; }
.dialog-title { font-size: 34rpx; font-weight: 600; text-align: center; margin-bottom: 30rpx; color: #333; }
.dialog-input { width: 100%; height: 80rpx; border: 1rpx solid #e8e8e8; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.dialog-btns { display: flex; gap: 20rpx; margin-top: 24rpx; }
.dialog-btn { flex: 1; height: 80rpx; line-height: 80rpx; text-align: center; border-radius: 12rpx; font-size: 30rpx; }
.dialog-cancel { background: #f5f5f5; color: #666; }
.dialog-confirm { background: #1A6FB5; color: #fff; }
