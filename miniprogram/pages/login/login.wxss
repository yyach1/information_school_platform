.login-page {
  min-height: 100vh;
  background: #f0f2f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  box-sizing: border-box;
}
.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}
.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a6fb5;
  display: block;
}
.login-desc {
  font-size: 26rpx;
  color: #909399;
  margin-top: 12rpx;
  display: block;
}
.login-form {
  width: 80%;
  max-width: 600rpx;
}
.input-group {
  margin-bottom: 30rpx;
}
.input-label {
  font-size: 28rpx;
  color: #303133;
  display: block;
  margin-bottom: 12rpx;
}
.input-field {
  background: #fff;
  border: 1rpx solid #dcdfe6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
}
.login-btn {
  width: 100%;
  background: #1a6fb5;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}
.login-tips {
  margin-top: 80rpx;
  text-align: center;
  font-size: 24rpx;
  color: #c0c4cc;
  line-height: 1.8;
}
.login-tips text {
  display: block;
}
